# Anthropic API Key（必填）
# 从 https://console.anthropic.com/ 获取
ANTHROPIC_API_KEY=your_api_key_here

# DuckDB 数据库文件路径（可选，默认为 ./data/sample.db）
DATABASE_PATH=./data/sample.db

# 模型选择（可选，默认使用 claude-sonnet-4-6）
# 可选值: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5
MODEL_NAME=claude-sonnet-4-6

# ---- 网络配置（中国大陆用户必读）----
# 如果遇到 403 Forbidden 或连接超时，说明需要配置代理访问 Anthropic API。
# 以下任选一种方式：

# 方式一：HTTP 代理（httpx 自动读取系统环境变量）
# 在终端中设置（或写入 ~/.bashrc / ~/.zshrc）：
#   export HTTPS_PROXY=http://127.0.0.1:7890
#   export HTTP_PROXY=http://127.0.0.1:7890

# 方式二：API 中继/反代（如果你有 Anthropic API 反代服务）
# ANTHROPIC_BASE_URL=https://your-api-relay.com
